
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read and write access for all authenticated users.
    // This is a permissive rule for development.
    // For production, you should restrict access based on user roles or ownership.
    // e.g., match /files/{userId}/{allPaths=**} { allow read, write: if request.auth.uid == userId; }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}

    