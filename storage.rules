
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // For a production app, you would likely want to restrict this
    // based on user authentication and ownership.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can upload files
    }
  }
}
