rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // WARNING: These rules are insecure and are meant for initial development only.
      // They allow public read and write access to your entire database.
      // You MUST secure these rules before launching your application.
      // For example, to allow only authenticated users to read and write:
      // allow read, write: if request.auth != null;
      allow read, write: if true;
    }
  }
}
