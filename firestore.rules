rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership or public access
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'content' collection
    match /content/{contentId} {
      // Allow read access for any authenticated user
      allow read: if request.auth != null;
      
      // Allow create, update, delete for any authenticated user
      // This is a permissive rule for the sake of the demo app.
      // In a real-world scenario, you would likely have more granular rules.
      allow write: if request.auth != null;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isOwner(userId);
      // Users can only create their own profile
      allow create: if isOwner(userId);
      // Users can only update their own profile
      allow update: if isOwner(userId);
      // Users cannot delete their profile through the client
      allow delete: if false;
    }
  }
}
