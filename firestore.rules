/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a user-ownership model for user profiles
 * and allows public read access for content, but restricts writes to authenticated users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data, accessible only by the user themselves.
 * - /content/{contentId}: Stores content items with public read access and authenticated-user-only write access.
 *
 * Key Security Decisions:
 * - User profiles are private and only accessible by the owning user.
 * - Content is publicly readable to allow for open access, but write access is restricted to authenticated users to prevent unauthorized modifications.
 * - No user listing is allowed to prevent enumeration.
 * - Data validation is minimized in this prototyping phase to facilitate rapid iteration.
 *
 * Denormalization for Authorization:
 *  - Content documents do not contain an explicit `ownerId` field.
 *  - For Content documents, writes are restricted to authenticated users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided user ID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces access control for user profile documents.
     * @path /users/{userId}
     * @allow (create) - A user can create their own profile if the userId matches their auth.uid.
     * @allow (get, list) - A user can read their own profile.
     * @allow (update, delete) - A user can update or delete their own profile.
     * @deny (create) - A user cannot create a profile with a different userId.
     * @deny (get, list) - A user cannot read another user's profile.
     * @deny (update, delete) - A user cannot modify or delete another user's profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces access control for content documents.
     * @path /content/{contentId}
     * @allow (get, list) - Anyone can read content.
     * @allow (create) - Only authenticated users can create content.
     * @allow (update, delete) - Only authenticated users can update or delete content.
     * @deny (create) - Unauthenticated users cannot create content.
     * @deny (update, delete) - Unauthenticated users cannot update or delete content.
     * @principle Allows public read access but restricts writes to authenticated users.
     */
    match /content/{contentId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}